# =============================================================================
# Gestion Total API — Variables de entorno
# Copiar a .env y completar con valores reales.
# NUNCA commitear el .env al repositorio.
# =============================================================================

# PostgreSQL (Neon o local)
# Formato para Neon:    postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?ssl=require
# Formato para local:   postgresql+asyncpg://postgres:password@localhost:5432/gestion-total-web
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/gestion-total-web

# JWT — generar con: openssl rand -hex 32
SECRET_KEY=CAMBIAR_POR_CLAVE_SECRETA_32_BYTES_HEX

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cloudinary (opcional en MVP — se usa para subir imágenes de productos)
# Crear cuenta en cloudinary.com, copiar de Dashboard > API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Entorno: development | production
ENVIRONMENT=development
